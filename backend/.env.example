# === Database ===
DATABASE_URL=postgresql+asyncpg://aria:ariapass@localhost:5432/aria
MONGO_URL=mongodb://aria:ariapass@localhost:27017/aria?authSource=admin
REDIS_URL=redis://localhost:6379/0

# === API Keys ===
# At least one vision API key required (Gemini, OpenAI, or Anthropic)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_MAPS_API_KEY=

# === Auth ===
JWT_SECRET=change-me-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Vision ===
# Comma-separated fallback order: gemini, openai, claude, local
VISION_PROVIDER_ORDER=gemini,openai,claude,local

# === Audio ===
AUDIO_OUTPUT_DIR=/app/audio_output
AUDIO_CLEANUP_MAX_AGE_SECONDS=300

# === App ===
APP_VERSION=1.0.0
DEBUG=false
