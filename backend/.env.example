# === API Keys ===
# At least one vision API key required (Gemini, OpenAI, or Anthropic)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# === Auth ===
JWT_SECRET=change-me-to-a-random-string

# === Vision ===
# Comma-separated fallback order: gemini, openai, claude, local
VISION_PROVIDER_ORDER=gemini,openai,claude,local

# === Debug ===
DEBUG=false
